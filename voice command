    <div class="voice-commands">
        <h3 style="color: #FFD700; text-align: center; margin-bottom: 15px;">AVAILABLE VOICE COMMANDS</h3>
        <div class="command-grid">
            <div class="command-item">
                <strong>"Initialize Global Control"</strong><br>
                <small>Activates worldwide system control</small>
            </div>
            <div class="command-item">
