<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Frank Kidelo Voice Command System - LIVE MICROPHONE API CONNECTED</title>
    <style>
        body {
            font-family: 'Courier New', monospace;
            background: linear-gradient(45deg, #000000, #1a1a1a);
            color: white;
            margin: 0;
            padding: 20px;
        }

        .voice-control-panel {
            background: rgba(0,0,0,0.9);
            border: 3px solid #FF0000;
            border-radius: 15px;
            padding: 30px;
            margin: 20px 0;
            text-align: center;
        }

        .voice-title {
            color: #FF0000;
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 20px;
            text-shadow: 0 0 15px #FF0000;
            animation: titlePulse 2s infinite;
        }

        @keyframes titlePulse {
            0%, 100% { text-shadow: 0 0 15px #FF0000; }
            50% { text-shadow: 0 0 30px #FF0000; }
        }

        .api-status {
            background: rgba(0,255,0,0.1);
            border: 2px solid #00FF00;
            border-radius: 10px;
            padding: 15px;
            margin: 20px 0;
            text-align: center;
        }

        .api-indicator {
            color: #00FF00;
            font-size: 1.1rem;
            font-weight: bold;
            animation: apiPulse 1.5s infinite;
        }

        @keyframes apiPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .microphone-btn {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: none;
            font-size: 2.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
            margin: 20px;
            position: relative;
            background: linear-gradient(45deg, #00FF00, #66FF66);
            color: black;
            animation: micActive 1s infinite;
            box-shadow: 0 0 25px #00FF00;
        }

        .microphone-btn.listening {
            background: linear-gradient(45deg, #FF0000, #FF6666);
            color: white;
            animation: micListening 0.5s infinite;
            box-shadow: 0 0 40px #FF0000;
        }

        .microphone-btn.processing {
            background: linear-gradient(45deg, #FFD700, #FFA500);
            color: black;
            animation: micProcessing 0.3s infinite;
            box-shadow: 0 0 35px #FFD700;
        }

        @keyframes micActive {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        @keyframes micListening {
            0%, 100% { transform: scale(1.1); }
            50% { transform: scale(1.2); }
        }

        @keyframes micProcessing {
            0%, 100% { transform: scale(1.05); }
            50% { transform: scale(1.15); }
        }

        .microphone-btn:hover {
            transform: scale(1.15);
            box-shadow: 0 0 40px #00FF00;
        }

        .voice-status {
            font-size: 1.1rem;
            margin: 15px 0;
            padding: 12px;
            border-radius: 8px;
            background: rgba(0,255,0,0.1);
            border: 2px solid #00FF00;
            color: #00FF00;
            animation: statusGlow 2s infinite;
        }

        @keyframes statusGlow {
            0%, 100% { box-shadow: 0 0 10px #00FF00; }
            50% { box-shadow: 0 0 20px #00FF00; }
        }

        .control-btn {
            padding: 12px 20px;
            margin: 8px;
            border: none;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            text-transform: uppercase;
            position: relative;
            overflow: hidden;
        }

        .btn-voice { 
            background: linear-gradient(45deg, #FF0000, #FF6666);
            color: white; 
        }

        .btn-broadcast { 
            background: linear-gradient(45deg, #FFD700, #FFA500);
            color: black; 
        }

        .btn-record { 
            background: linear-gradient(45deg, #00FF00, #66FF66);
            color: black; 
        }

        .btn-emergency { 
            background: linear-gradient(45deg, #FF4500, #FF6347);
            color: white; 
        }

        .control-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px currentColor;
        }

        .control-btn.processing {
            background: linear-gradient(45deg, #00AA00, #00CC00);
            animation: processing 1s infinite;
        }

        @keyframes processing {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .control-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .voice-commands {
            background: rgba(0,0,0,0.8);
            border: 2px solid #FFD700;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
            text-align: left;
        }

        .command-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 10px;
            margin-top: 15px;
        }

        .command-item {
            background: rgba(255,255,255,0.1);
            padding: 10px;
            border-radius: 5px;
            border-left: 4px solid #00FF00;
            transition: all 0.3s ease;
        }

        .command-item:hover {
            background: rgba(255,255,255,0.2);
            transform: translateX(5px);
        }

        .presidents-panel {
            background: rgba(0,0,0,0.8);
            border: 2px solid #00FF00;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
        }

        .president-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 10px;
            margin-top: 15px;
        }

        .president-item {
            background: rgba(0,255,0,0.1);
            border: 1px solid #00FF00;
            border-radius: 5px;
            padding: 8px;
            text-align: center;
            font-size: 0.85rem;
            transition: all 0.3s ease;
        }

        .president-item.broadcasting {
            background: rgba(255,0,0,0.3);
            border-color: #FF0000;
            animation: broadcast 1s infinite;
        }

        @keyframes broadcast {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .voice-terminal {
            background: #000000;
            color: #00FF00;
            padding: 20px;
            border-radius: 10px;
            font-family: 'Courier New', monospace;
            height: 300px;
            overflow-y: auto;
            border: 2px solid #00FF00;
            margin: 20px 0;
            box-shadow: 0 0 15px rgba(0,255,0,0.3);
        }

        .terminal-line {
            margin: 3px 0;
            animation: terminalType 0.3s ease-in-out;
        }

        @keyframes terminalType {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .audio-visualizer {
            width: 100%;
            height: 60px;
            background: #000;
            border: 1px solid #00FF00;
            border-radius: 5px;
            margin: 15px 0;
            position: relative;
            overflow: hidden;
        }

        .visualizer-bar {
            position: absolute;
            bottom: 0;
            width: 3px;
            background: linear-gradient(to top, #00FF00, #FFD700, #FF0000);
            transition: height 0.1s ease;
        }

        .speech-bubble {
            background: rgba(255,215,0,0.1);
            border: 2px solid #FFD700;
            border-radius: 15px;
            padding: 15px;
            margin: 15px 0;
            position: relative;
            animation: speechGlow 2s infinite;
        }

        @keyframes speechGlow {
            0%, 100% { box-shadow: 0 0 15px rgba(255,215,0,0.3); }
            50% { box-shadow: 0 0 25px rgba(255,215,0,0.6); }
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            background: #00FF00;
            color: black;
            padding: 15px 20px;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            z-index: 10001;
            animation: slideInRight 0.3s ease;
            font-weight: bold;
            max-width: 400px;
        }

        @keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</head>
<body>
    <!-- Live API Status -->
    <div class="api-status">
        <h3 style="color: #00FF00; margin-bottom: 10px;">🎤 LIVE MICROPHONE API STATUS</h3>
        <div class="api-indicator">
            ✅ Microphone API: <span id="mic-api-status">CONNECTED</span> | 
            ✅ Speech Recognition: <span id="speech-status">ACTIVE</span> | 
